rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(clientId) {
      return isAuthenticated() && request.auth.uid == clientId;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // --- OPERATIONS: JOBS & ASSETS ---
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- PROJECTS & CLIENT DATA ---
    match /projects/{projectId} {
      // Allow read if user is Admin OR the owner of the project
      allow read: if isAdmin() || isOwner(resource.data.clientId);
      allow write: if isAdmin();

      // Deep Sub-collections (Payments, Media, Notes, Tasks)
      match /{subcollection}/{docId} {
        allow read: if isAdmin() || isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.clientId);
        allow write: if isAdmin();
      }
    }

    // --- PUBLIC & SHARED COLLECTIONS ---
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow create: if true; // Public can book
    }
    
    match /proposals/{proposalId} {
      allow read, write: if isAdmin();
    }

    match /cms_content/{docId} {
      allow read: if true; // Public can read site content
      allow write: if isAdmin();
    }

    match /notifications/{notifId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if true; // System-wide notifications
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    match /testimonials/{testId} {
      allow read: if true; // Public can see testimonials
      allow create: if true; // Public can submit
      allow update, delete: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId));
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /invoices/{invId} {
       allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.clientEmail);
       allow write: if isAdmin();
    }

    match /activity_logs/{logId} {
       allow read, write: if isAdmin();
    }
  }
}
