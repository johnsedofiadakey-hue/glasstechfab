rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // HELPER FUNCTIONS
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email.matches(".*@glasstechfab.com") ||
        request.auth.token.email == "contact@glasstech.com.gh" ||
        request.auth.uid == "qRcOaTkJ6rYmjha9jNAadrYW6pK2" || // Super Admin
        request.auth.uid == "pBkrb38P9NaXXjIILQXlqxxC33p2" || // Factory Admin
        request.auth.uid == "GQL4qVw3NIe9XVq8gZFkuU4Q9dD3" || // Authorized Test Account
        request.auth.uid == "GQL4qVw3NIe9XVq8gZFkuU4Q9dd3"    // Current Active UID
      );
    }

    function isOwner(clientId) {
      return isAuthenticated() && request.auth.uid == clientId;
    }

    // --- USER PROFILES ---
    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin();
      allow write: if isAdmin() || request.auth.uid == userId;
    }

    // --- OPERATIONS: JOBS & ASSETS ---
    match /jobs/{jobId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /assets/{assetId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // --- PROJECTS & CLIENT DATA ---
    match /projects/{projectId} {
      // Allow read if user is Admin OR the owner of the project (by UID or Email)
      allow get: if isAdmin() || isOwner(resource.data.clientId) || (isAuthenticated() && request.auth.token.email == resource.data.email);
      allow list: if isAdmin() || (isAuthenticated() && (request.query.limit <= 100)); // Allow clients to query projects
      allow write: if isAdmin();

      // Deep Sub-collections (Payments, Media, Notes, Tasks)
      match /{subcollection}/{docId} {
        allow get: if isAdmin() || isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.clientId);
        allow list: if isAdmin() || isOwner(get(/databases/$(database)/documents/projects/$(projectId)).data.clientId);
        allow write: if isAdmin();
      }
    }

    // --- PUBLIC & SHARED COLLECTIONS ---
    match /bookings/{bookingId} {
      allow read: if isAdmin();
      allow create: if true; // Public can book
    }
    
    match /proposals/{proposalId} {
      allow read, write: if isAdmin();
    }    
    match /cms_content/{docId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
       allow read, write: if true;
    }
    match /notifications/{notifId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
      allow create: if true; 
      allow update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    match /portfolio/{projId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /products/{prodId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /testimonials/{testId} {
      allow read: if true; // Public can see testimonials
      allow create: if true; // Public can submit
      allow update, delete: if isAdmin();
    }

    match /messages/{msgId} {
      allow read: if isAdmin() || (isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId));
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /showcase/{sceneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /emails/{emailId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email == resource.data.to);
      allow write: if isAdmin();
      allow create: if true; // Public can send inquiries
    }

    match /work_orders/{id} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }
    match /containers/{id} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin();
    }
    // --- GLOBAL ADMIN COLLECTIONS ---
    match /transactions/{txId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /shipments/{shipId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /invoices/{invId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /tasks/{taskId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /procurements/{procId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /activity_logs/{logId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin();
      allow write: if isAdmin(); 
    }
    match /messages/{msgId} { 
      allow get: if isAuthenticated(); 
      allow list: if isAuthenticated();
      allow write: if isAuthenticated(); 
    }
    match /approvals/{id} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /change_requests/{id} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /notes/{id} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /media/{id} { 
      allow get: if isAuthenticated(); 
      allow list: if isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow write: if isAdmin(); 
    }
    match /testimonials/{id} { allow read: if true; allow write: if isAuthenticated(); }
  }
}
