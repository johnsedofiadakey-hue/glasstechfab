rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isManagerOf(projectId) {
      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.managerId;
    }
    
    function isProjectOwner(projectId) {
      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.clientId;
    }

    // Users
    match /users/{userId} {
      allow read, list: if true;
      allow write: if true; // Temporary for setup
    }

    // Notifications (Global)
    match /notifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Projects (Standardized Structure)
    match /projects/{projectId} {
      allow read, write: if true; // Temporarily open for initialization

      match /{subcollection}/{docId} {
        allow read, write: if true;
      }
    }

     // Collection Group Access
    match /{path=**}/tasks/{taskId} { allow read, write: if true; }
    match /{path=**}/payments/{paymentId} { allow read, write: if true; }
    match /{path=**}/procurements/{shipmentId} { allow read, write: if true; }
    match /{path=**}/approvals/{apprId} { allow read, write: if true; }
    match /{path=**}/change_requests/{crId} { allow read, write: if true; }
    match /{path=**}/activity_logs/{logId} { allow read, write: if true; }
    match /{path=**}/media/{id} { allow read, write: if true; }
    match /{path=**}/notes/{id} { allow read, write: if true; }
    match /{path=**}/transactions/{id} { allow read, write: if true; }
    match /{path=**}/materials/{id} { allow read, write: if true; }
    match /{path=**}/emails/{id} { allow read, write: if true; }

    // Root Level Shared
    match /assets/{id} { allow read: if true; allow write: if isAdmin(); }
    match /proposals/{id} { allow read: if true; allow write: if isAdmin(); }
    match /bookings/{id} { allow read, write: if true; }

    // CMS & Brand
    match /cms_content/{docId} {
      allow read: if true;
      allow write: if true; // Temporary for setup
    }
  }
}
