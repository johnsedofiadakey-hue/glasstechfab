VITE_CLAUDE_API_KEY=your_key_here
VITE_STRIPE_PUBLIC_KEY=your_key_here

# WHATSAPP MESSAGING (options: meta, twilio, mock)
VITE_WHATSAPP_PROVIDER=mock

# META WHATSAPP CLOUD API
VITE_META_WHATSAPP_TOKEN=your_permanent_access_token
VITE_META_WHATSAPP_PHONE_ID=your_phone_number_id
VITE_META_WHATSAPP_TEMPLATE_NAME=your_approved_template_name

# TWILIO WHATSAPP
VITE_TWILIO_SID=your_twilio_sid
VITE_TWILIO_TOKEN=your_twilio_token
VITE_TWILIO_SENDER=whatsapp:your_twilio_number
