[debug] [2026-03-30T08:09:38.619Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/glasstechfab-635c2/rulesets {"name":"projects/glasstechfab-635c2/rulesets/b2f54d0f-a407-4eb9-aea7-664b07294bd6","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper functions\n    function isAdmin() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    \n    function isManagerOf(projectId) {\n      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.managerId;\n    }\n    \n    function isProjectOwner(projectId) {\n      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.clientId;\n    }\n\n    // Users\n    match /users/{userId} {\n      // Allow any logged-in user to read/list profiles (needed for email matching and team views)\n      allow read, list: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    // Notifications (Global)\n    match /notifications/{notifId} {\n      allow read: if request.auth != null && (isAdmin() || request.auth.uid == resource.data.userId);\n      allow write: if request.auth != null && (isAdmin() || request.auth.uid == request.resource.data.userId);\n    }\n\n    // Projects (Standardized Structure)\n    match /projects/{projectId} {\n      allow read: if isAdmin() || isManagerOf(projectId) || isProjectOwner(projectId);\n      allow write: if isAdmin() || isManagerOf(projectId);\n\n      // Subcollections (Standardized)\n      match /approvals/{apprId} {\n        allow read: if isAdmin() || isManagerOf(projectId) || isProjectOwner(projectId);\n        allow create: if isAdmin() || isManagerOf(projectId);\n        allow update: if (isAdmin() || isManagerOf(projectId)) && resource.data.status != 'approved';\n        allow update: if isProjectOwner(projectId) && \n                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'comment', 'approvedAt']) &&\n                      resource.data.status == 'pending';\n        allow delete: if isAdmin();\n      }\n\n      match /change_requests/{crId} {\n        allow read: if isAdmin() || isManagerOf(projectId) || isProjectOwner(projectId);\n        allow create: if isProjectOwner(projectId);\n        allow update: if (isAdmin() || isManagerOf(projectId)) && \n                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['costImpact', 'timelineImpact', 'status']);\n        allow update: if isProjectOwner(projectId) && \n                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&\n                      resource.data.status == 'evaluated';\n        allow delete: if isAdmin();\n      }\n\n      match /{subcollection}/{docId} {\n        allow read: if isAdmin() || isManagerOf(projectId) || isProjectOwner(projectId);\n        allow write: if isAdmin() || isManagerOf(projectId);\n      }\n    }\n\n    // Collection Group Access (Optimized for Admins)\n    match /{path=**}/tasks/{taskId} { allow read: if request.auth != null && (isAdmin() || resource.data.assignedTo == request.auth.uid); }\n    match /{path=**}/payments/{paymentId} { allow read: if request.auth != null && (isAdmin() || isProjectOwner(get(resource.__name__.parent().parent()).id)); }\n    match /{path=**}/shipments/{shipmentId} { allow read: if request.auth != null; }\n    match /{path=**}/approvals/{apprId} { allow read: if request.auth != null; }\n    match /{path=**}/change_requests/{crId} { allow read: if request.auth != null; }\n    match /{path=**}/activity_logs/{logId} { allow read: if request.auth != null; }\n\n    // CMS & Brand\n    match /cms_content/{docId} {\n      allow read: if true;\n      allow write: if isAdmin();\n    }\n  }\n}\n","name":"firebase/firestore.rules"}]},"createTime":"2026-03-30T08:09:38.783199Z","metadata":{"services":["cloud.firestore"]}}
