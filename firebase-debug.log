[debug] [2026-03-30T08:14:45.850Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/glasstechfab-635c2/rulesets {"name":"projects/glasstechfab-635c2/rulesets/47a39ed8-33d6-450e-be2a-0c2c1a0cbacc","source":{"files":[{"content":"rules_version = '2';\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    \n    // Helper functions\n    function isAdmin() {\n      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';\n    }\n    \n    function isManagerOf(projectId) {\n      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.managerId;\n    }\n    \n    function isProjectOwner(projectId) {\n      return request.auth.uid == get(/databases/$(database)/documents/projects/$(projectId)).data.clientId;\n    }\n\n    // Users\n    match /users/{userId} {\n      allow read, list: if true;\n      allow write: if true; // Temporary for setup\n    }\n\n    // Notifications (Global)\n    match /notifications/{notifId} {\n      allow read: if request.auth != null;\n      allow write: if request.auth != null;\n    }\n\n    // Projects (Standardized Structure)\n    match /projects/{projectId} {\n      allow read, write: if true; // Temporarily open for initialization\n\n      match /{subcollection}/{docId} {\n        allow read, write: if true;\n      }\n    }\n\n    // Collection Group Access\n    match /{path=**}/tasks/{taskId} { allow read, write: if true; }\n    match /{path=**}/payments/{paymentId} { allow read, write: if true; }\n    match /{path=**}/shipments/{shipmentId} { allow read, write: if true; }\n    match /{path=**}/approvals/{apprId} { allow read, write: if true; }\n    match /{path=**}/change_requests/{crId} { allow read, write: if true; }\n    match /{path=**}/activity_logs/{logId} { allow read, write: if true; }\n\n    // CMS & Brand\n    match /cms_content/{docId} {\n      allow read: if true;\n      allow write: if true; // Temporary for setup\n    }\n  }\n}\n","name":"firebase/firestore.rules"}]},"createTime":"2026-03-30T08:14:45.989839Z","metadata":{"services":["cloud.firestore"]}}
